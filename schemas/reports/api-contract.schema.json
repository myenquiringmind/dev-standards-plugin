{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dev-standards-plugin/schemas/reports/api-contract.schema.json",
  "title": "API Contract Report",
  "description": "Produced by api-contract-extractor. Catalogs every API contract declared in the project's source — OpenAPI / Swagger spec files, tRPC router definitions, GraphQL schemas. Phase 3 ships first-class OpenAPI parsing; tRPC and GraphQL contracts capture presence + minimal counts only, with full parsing deferred to Phase 6+ stack agents. Source-only; no live API calls.",
  "type": "object",
  "required": ["generated_at", "project_dir", "summary", "contracts"],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "project_dir": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "required": ["contract_count", "openapi_count", "trpc_count", "graphql_count", "total_paths"],
      "additionalProperties": false,
      "properties": {
        "contract_count": { "type": "integer", "minimum": 0 },
        "openapi_count": { "type": "integer", "minimum": 0 },
        "trpc_count": { "type": "integer", "minimum": 0 },
        "graphql_count": { "type": "integer", "minimum": 0 },
        "total_paths": {
          "type": "integer",
          "minimum": 0,
          "description": "Sum of paths.length across all OpenAPI contracts. tRPC procedures and GraphQL operations are not counted here — only OpenAPI paths."
        }
      }
    },
    "contracts": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/OpenApiContract" },
          { "$ref": "#/$defs/TrpcContract" },
          { "$ref": "#/$defs/GraphqlContract" }
        ]
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "OpenApiContract": {
      "type": "object",
      "required": ["kind", "source_file", "version", "paths"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "openapi" },
        "source_file": { "type": "string", "minLength": 1 },
        "version": {
          "type": "string",
          "pattern": "^(openapi-3|swagger-2\\.0)$",
          "description": "Normalised version label: openapi-3 for OpenAPI 3.x, swagger-2.0 for Swagger 2.0."
        },
        "title": { "type": ["string", "null"] },
        "info_version": { "type": ["string", "null"] },
        "paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/OpenApiPath" }
        },
        "note": {
          "type": "string",
          "description": "Per-contract note (e.g. parse failure detail). Omitted when the contract parsed cleanly."
        }
      }
    },
    "OpenApiPath": {
      "type": "object",
      "required": ["method", "path"],
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS", "TRACE"]
        },
        "path": { "type": "string", "minLength": 1 },
        "operationId": { "type": ["string", "null"] },
        "summary": { "type": ["string", "null"] }
      }
    },
    "TrpcContract": {
      "type": "object",
      "required": ["kind", "source_file", "router_names"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "trpc" },
        "source_file": { "type": "string", "minLength": 1 },
        "router_names": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "description": "Best-effort router identifiers extracted from `export const <name>Router = ...` patterns. May be empty when names cannot be recovered without AST parsing — Phase 6+ stack agents fill this in."
        }
      }
    },
    "GraphqlContract": {
      "type": "object",
      "required": ["kind", "source_file", "types_count", "queries_count", "mutations_count", "subscriptions_count"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "graphql" },
        "source_file": { "type": "string", "minLength": 1 },
        "types_count": { "type": "integer", "minimum": 0 },
        "queries_count": { "type": "integer", "minimum": 0 },
        "mutations_count": { "type": "integer", "minimum": 0 },
        "subscriptions_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
