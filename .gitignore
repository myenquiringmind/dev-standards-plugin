# Local overrides
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.nul
nul

# Editor files
*.swo
.idea/
.vscode/
*.sublime-*
.project
.classpath
.settings/

# Logs
*.log

# Node.js
node_modules/
npm-debug.log*

# Python
*.pyc
__pycache__/
/.venv/
/venv/
/.uv/
# Don't ignore lib/venv (plugin module)
!lib/venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
dist/
build/
*.pyo
*.pyd

# Test artifacts
coverage/
.nyc_output/

# Local temp directory (per housekeeping standards)
tmp/

# Backup/old files
*.old.js
*.bak

# Version cache
.claude-plugin-version-cache.json

# Secrets and credentials (CRITICAL - never commit these)
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
credentials.json
secrets.json
.secrets/

# Cache files
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Temporary files
temp/
.tmp/
*.tmp

# Orchestrator state (local only)
tmp/.orchestrator-state.json

# Derived artifact — rebuilt by scripts/build_graph_registry.py
config/graph-registry.json

# Ephemeral validation stamps — written by /validate, consumed by
# pre_commit_cli_gate. 15-minute TTL, branch-scoped.
.validation_stamp
.frontend_validation_stamp
.agent_validation_stamp
.db_validation_stamp
.api_validation_stamp

# Context-usage cache — written by statusline.py, read by context_budget.py
.claude/.context_pct

# Archived session state — produced by session_start.py after reinjection
**/memory/session-state.md.injected

# Session-checkpoint counter state
**/memory/session-checkpoint.state.json
