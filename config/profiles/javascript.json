{
  "$schema": "../../schemas/profile.schema.json",
  "name": "javascript",
  "priority": "P0",
  "detection": {
    "markers": ["package.json"],
    "extensions": [".js", ".jsx", ".ts", ".tsx"]
  },
  "tools": {
    "formatter": {
      "command": "prettier --write {file}",
      "extensions": [".js", ".jsx", ".ts", ".tsx"]
    },
    "linter": {
      "command": "eslint {file}",
      "extensions": [".js", ".jsx", ".ts", ".tsx"],
      "args": ["--fix"]
    },
    "typeChecker": {
      "command": "tsc --noEmit",
      "extensions": [".ts", ".tsx"]
    }
  },
  "packageManager": {
    "preferred": "npm",
    "fallback": "pnpm",
    "lockfile": "package-lock.json"
  },
  "validationSteps": [
    "eslint",
    "tsc-strict",
    "vitest",
    "fe-code-simplifier",
    "fe-security-reviewer",
    "fe-doc-checker",
    "fe-component-reviewer"
  ],
  "conventions": {
    "fileNaming": "kebab-case",
    "functionNaming": "camelCase",
    "classNaming": "PascalCase",
    "constantNaming": "SCREAMING_SNAKE",
    "variableNaming": "camelCase",
    "docstringStyle": "jsdoc"
  }
}
